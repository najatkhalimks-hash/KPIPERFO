# =============================================================
# GSMI Researcher Platform — Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs
# =============================================================

# Supabase (obligatoire)
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Application
VITE_APP_NAME=Carnet du Chercheur GSMI
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Intégrations externes (optionnel)
VITE_CROSSREF_API_BASE=https://api.crossref.org
VITE_OPENALEX_API_BASE=https://api.openalex.org
VITE_ORCID_API_BASE=https://pub.orcid.org/v3.0
